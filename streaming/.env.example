# ── Server ────────────────────────────────────────────────────────────────────
PORT=5050
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=your-voice-id
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Maximum characters to send to TTS per turn (longer text is sentence-truncated)
MAX_TTS_CHARS=180

# Milliseconds to wait for ElevenLabs before falling back to Twilio <Say>
TTS_TIMEOUT_MS=2500

# ── ElevenLabs voice tuning ───────────────────────────────────────────────────
ELEVEN_STABILITY=0.55
ELEVEN_SIMILARITY=0.85
ELEVEN_STYLE=0.15
ELEVEN_SPEAKER_BOOST=true
