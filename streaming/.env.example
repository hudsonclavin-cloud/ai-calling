# ── Server ────────────────────────────────────────────────────────────────────
PORT=5050
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok-free.app
# Public URL of the Next.js web app (used in email CTAs and Stripe redirect URLs)
WEB_BASE_URL=https://your-web-app.up.railway.app
# Secret key for /api/admin/* routes — set x-admin-key header to this value
ADMIN_API_KEY=change-me-in-production

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=sk_...
ELEVENLABS_VOICE_ID=your-voice-id
ELEVENLABS_MODEL_ID=eleven_turbo_v2_5

# Maximum characters to send to TTS per turn (longer text is sentence-truncated)
MAX_TTS_CHARS=180

# Milliseconds to wait for ElevenLabs before falling back to Twilio <Say>
TTS_TIMEOUT_MS=2500

# ── ElevenLabs voice tuning ───────────────────────────────────────────────────
# Voice naturalness tuning (lower stability = more variation, higher style = more expressive)
ELEVEN_STABILITY=0.40
ELEVEN_SIMILARITY=0.75
ELEVEN_STYLE=0.35
ELEVEN_SPEAKER_BOOST=true
ELEVEN_SPEED=1.0
# Max ms to wait for ElevenLabs AFTER OpenAI returns (falls back to Twilio <Say> if exceeded)
TTS_BUDGET_MS=900

# ── Notifications ─────────────────────────────────────────────────────────────
# Email via Resend (https://resend.com) — fired when an intake call completes
RESEND_API_KEY=re_...
# "From" address — must be a verified domain in Resend (use onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=onboarding@resend.dev

# SMS via Twilio REST API — set notification_phone on the firm config to enable
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+14155550199
